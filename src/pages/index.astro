---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.jpg';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 1);

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function readingTime(content: string): string {
  const words = content.split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min read`;
}
---

<BaseLayout title="Home">
  <!-- Author Card -->
  <section class="author-card">
    <h1 class="author-name">Swarnim Bandekar</h1>
    <p class="author-bio">
      Security researcher with an offensive focus. I break things to understand how they work, then write about it.
    </p>
    <p class="author-bio">
      CTF writeups, vulnerability research, and bug bounty findings from the trenches.
    </p>
  </section>

  <!-- Latest Posts -->
  {posts.length > 0 && (
    <>
      <h2 class="section-heading">Latest</h2>

      {posts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="post-card">
          {post.data.cover && (
            <Image src={post.data.cover} alt={post.data.title} width={200} height={130} class="post-card-image" loading="lazy" />
          )}
          <div class="post-card-content">
            <h3 class="post-card-title">{post.data.title}</h3>
            <p class="post-card-desc">{post.data.description}</p>
            <div class="post-card-meta">
              <span>{formatDate(post.data.date)}</span>
              <span class="sep">/</span>
              <span>{readingTime(post.body ?? '')}</span>
            </div>
            {post.data.tags.length > 0 && (
              <div class="post-card-tags">
                {post.data.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}

      <a href="/blog" class="section-link">
        View all posts →
      </a>
    </>
  )}
</BaseLayout>
