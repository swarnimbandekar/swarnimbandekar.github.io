---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="Privacy policy for swarnimbandekar.">
  <div class="about-content">
    <div class="page-header">
      <h1 class="page-title">Privacy Policy</h1>
    </div>

    <div class="prose">
      <p><em>Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</em></p>

      <p>
        This website is a personal blog focused on security research. Your privacy matters, and this policy explains what information is collected and how it is used.
      </p>

      <h2>Information We Collect</h2>
      <p>
        This site does not require registration and does not collect personal information directly. Standard, non-identifying technical data (such as browser type and pages visited) may be processed by the hosting provider for security and analytics purposes.
      </p>

      <h2>Cookies</h2>
      <p>
        A single local-storage value is used to remember your light/dark theme preference. No tracking cookies are set by this site.
      </p>

      <h2>Third-Party Links</h2>
      <p>
        Posts may link to external sites (GitHub, LinkedIn, X, Medium, and others). This policy does not cover those sites; please review their respective privacy policies.
      </p>

      <h2>Contact</h2>
      <p>
        For any privacy-related questions, reach out via the <a href="/contact">Contact</a> page.
      </p>
    </div>
  </div>
</BaseLayout>
