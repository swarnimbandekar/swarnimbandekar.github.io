---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.jpg';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  wide?: boolean;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
  jsonLd?: Record<string, any>;
}

const {
  title,
  description = 'Security researcher focused on offensive security, red teaming, web security, api security, osint, and bug bounty hunting.',
  ogImage = '/static/og.png',
  canonicalURL = Astro.url.href,
  wide = false,
  article,
  jsonLd,
} = Astro.props;

const siteTitle = 'swarnimbandekar';
const fullTitle = title === 'Home' ? siteTitle : `${title} | ${siteTitle}`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <meta name="theme-color" content="#0c0c0c" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:site_name" content={siteTitle} />
  <meta property="og:url" content={canonicalURL} />

  {article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
  {article?.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
  {article?.author && <meta property="article:author" content={article.author} />}
  {article?.tags?.map((tag: string) => <meta property="article:tag" content={tag} />)}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <meta name="author" content="swarnimbandekar" />
  {article?.tags && <meta name="keywords" content={article.tags.join(', ')} />}

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/style.css" rel="stylesheet" />

  <link rel="icon" type="image/jpeg" href="/static/logo.jpg" />
  <link rel="apple-touch-icon" href="/static/logo.jpg" />
  <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Inline theme script to prevent flash -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
      }
    })();
  </script>

  <!-- Hacker Cursor Effect -->
  <script is:inline>
    (function() {
      // Only enable on devices with mouse
      if (window.matchMedia('(hover: none) and (pointer: coarse)').matches) return;

      const cursor = document.createElement('div');
      cursor.className = 'hacker-cursor';
      cursor.innerHTML = '<div class="hacker-cursor-dot"></div><div class="hacker-cursor-ring"></div>';
      cursor.style.left = '-100px';
      cursor.style.top = '-100px';
      document.body.appendChild(cursor);

      const trailsContainer = document.createElement('div');
      trailsContainer.className = 'cursor-trails';
      document.body.appendChild(trailsContainer);

      const trailCount = 12;
      const trails = [];

      for (let i = 0; i < trailCount; i++) {
        const trail = document.createElement('div');
        trail.className = 'hacker-cursor-trail';
        trail.style.opacity = (1 - i / trailCount) * 0.7;
        trail.style.left = '-100px';
        trail.style.top = '-100px';
        trailsContainer.appendChild(trail);
        trails.push({ el: trail, x: -100, y: -100 });
      }

      let mouseX = -100, mouseY = -100;
      let cursorX = -100, cursorY = -100;
      let isVisible = false;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        if (!isVisible) {
          isVisible = true;
          cursor.style.opacity = '1';
          trailsContainer.style.opacity = '1';
        }
      });

      document.addEventListener('mouseout', () => {
        cursor.style.opacity = '0';
        trailsContainer.style.opacity = '0';
        isVisible = false;
      });

      document.addEventListener('mouseover', () => {
        if (mouseX > 0) {
          cursor.style.opacity = '1';
          trailsContainer.style.opacity = '1';
          isVisible = true;
        }
      });

      function animate() {
        cursorX += (mouseX - cursorX) * 0.2;
        cursorY += (mouseY - cursorY) * 0.2;

        cursor.style.left = cursorX + 'px';
        cursor.style.top = cursorY + 'px';

        for (let i = 0; i < trails.length; i++) {
          const targetX = i === 0 ? cursorX : trails[i - 1].x;
          const targetY = i === 0 ? cursorY : trails[i - 1].y;

          trails[i].x += (targetX - trails[i].x) * (0.25 - i * 0.015);
          trails[i].y += (targetY - trails[i].y) * (0.25 - i * 0.015);

          trails[i].el.style.left = trails[i].x + 'px';
          trails[i].el.style.top = trails[i].y + 'px';
        }

        requestAnimationFrame(animate);
      }

      animate();

      function updateCursorColor() {
        const isDark = document.documentElement.classList.contains('dark');
        const color = isDark ? '#46d369' : '#15803d';
        document.documentElement.style.setProperty('--cursor-color', color);
      }

      updateCursorColor();

      const observer = new MutationObserver(updateCursorColor);
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    })();
  </script>
</head>
<body>
  <div class="site-wrapper">
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="header-logo">
          <Image src={logoImg} alt="Logo" width={28} height={28} style="border-radius: 50%; object-fit: cover;" />
          <span>swarnimbandekar</span>
        </a>
        <div class="header-right">
          <nav class="header-nav">
            <a href="/blog" class:list={[{ active: Astro.url.pathname.startsWith('/blog') }]}>Blog</a>
            <a href="/about" class:list={[{ active: Astro.url.pathname === '/about' || Astro.url.pathname === '/about/' }]}>About</a>
          </nav>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </button>
        </div>
      </div>
    </header>

    <main class:list={['content-wrapper', { 'content-wrapper--wide': wide }]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-links">
          <a href="https://github.com/swarnimbandekar" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/swarnimbandekar/" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
          <a href="https://x.com/swarnimsb" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16h-4.267z"/><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"/></svg>
            X
          </a>
          <a href="https://medium.com/@swarnimbandekar" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="M8 8h.01"/><path d="M8 12h.01"/><path d="M8 16h.01"/><path d="M12 8h4"/><path d="M12 12h4"/><path d="M12 16h4"/></svg>
            Medium
          </a>
          <a href="/rss.xml" target="_blank">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
            RSS
          </a>
        </div>
        <span class="footer-copy">&copy; {new Date().getFullYear()} swarnimbandekar</span>
      </div>
    </footer>
  </div>

  <script is:inline>
    document.getElementById('theme-toggle').addEventListener('click', function() {
      const html = document.documentElement;
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        html.classList.add('light');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.remove('light');
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  </script>

  <script is:inline>
    (function() {
      // Skip on touch devices
      if (window.matchMedia('(hover: none) and (pointer: coarse)').matches) return;

      // Create cursor element
      var cursor = document.createElement('div');
      cursor.className = 'hacker-cursor';
      cursor.innerHTML = '<div class="hacker-cursor-dot"></div><div class="hacker-cursor-ring"></div>';
      document.body.appendChild(cursor);

      // Create trail container
      var trailBox = document.createElement('div');
      trailBox.className = 'cursor-trails';
      document.body.appendChild(trailBox);

      var mx = -100, my = -100;
      var cx = -100, cy = -100;
      var trails = [];
      var MAX_TRAILS = 8;
      var trailIdx = 0;

      // Pre-create trail dots
      for (var i = 0; i < MAX_TRAILS; i++) {
        var dot = document.createElement('div');
        dot.className = 'hacker-cursor-trail';
        dot.style.opacity = '0';
        trailBox.appendChild(dot);
        trails.push({ el: dot, x: -100, y: -100 });
      }

      document.addEventListener('mousemove', function(e) {
        mx = e.clientX;
        my = e.clientY;
      });

      // Show/hide on enter/leave
      document.addEventListener('mouseenter', function() {
        cursor.style.opacity = '1';
      });
      document.addEventListener('mouseleave', function() {
        cursor.style.opacity = '0';
        for (var i = 0; i < trails.length; i++) {
          trails[i].el.style.opacity = '0';
        }
      });

      var lastTrailTime = 0;

      function tick() {
        // Smooth follow
        cx += (mx - cx) * 0.15;
        cy += (my - cy) * 0.15;
        cursor.style.left = cx + 'px';
        cursor.style.top = cy + 'px';

        // Spawn trail dots
        var now = Date.now();
        if (now - lastTrailTime > 40) {
          var t = trails[trailIdx % MAX_TRAILS];
          t.x = cx;
          t.y = cy;
          t.el.style.left = cx - 3 + 'px';
          t.el.style.top = cy - 3 + 'px';
          t.el.style.opacity = '0.5';
          t.birth = now;
          trailIdx++;
          lastTrailTime = now;
        }

        // Fade trail dots
        for (var i = 0; i < trails.length; i++) {
          if (trails[i].birth) {
            var age = now - trails[i].birth;
            var op = Math.max(0, 0.5 - age / 400);
            trails[i].el.style.opacity = op;
          }
        }

        requestAnimationFrame(tick);
      }

      tick();
    })();
  </script>
</body>
</html>
