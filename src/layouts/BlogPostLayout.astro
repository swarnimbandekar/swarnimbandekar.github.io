---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.jpg';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
}

const { post, headings, prevPost, nextPost } = Astro.props;
const { title, description, date, tags, cover, faq } = post.data;

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function readingTime(content: string): string {
  const words = content.split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min read`;
}

const tocItems = headings.filter(h => h.depth <= 4);

const articleMeta = {
  publishedTime: date.toISOString(),
  author: 'swarnimbandekar',
  tags,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: 'swarnimbandekar',
    url: 'https://swarnimbandekar.in',
  },
  datePublished: date.toISOString(),
  image: cover ? new URL(cover, 'https://swarnimbandekar.in').href : undefined,
  url: Astro.url.href,
  keywords: tags.join(', '),
};

const faqLd = faq?.length && {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const schema = faqLd ? [jsonLd, faqLd] : jsonLd;
---

<BaseLayout title={title} description={description} wide={true} article={articleMeta} jsonLd={schema} ogImage={cover}>
  <article class="post-layout">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs">
      <a href="/">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </a>
      <span class="bc-sep">›</span>
      <a href="/blog">Blog</a>
      <span class="bc-sep">›</span>
      <span>{title}</span>
    </nav>

    <!-- Post Header -->
    <header class="post-header post-header--wide">
      <h1 class="post-header-title">{title}</h1>
      <div class="post-header-meta">
        <Image src={logoImg} alt="avatar" width={20} height={20} loading="eager" style="border-radius: 50%; object-fit: cover;" />
        <span>swarnimbandekar</span>
        <span class="sep">|</span>
        <span>{formatDate(date)}</span>
        <span class="sep">|</span>
        <span>{readingTime(post.body ?? '')}</span>
      </div>
      {tags.length > 0 && (
        <div class="post-header-tags">
          {tags.map((tag: string) => (
            <span class="tag"><span class="tag-hash">#</span> {tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Prev/Next Navigation Top -->
    {(prevPost || nextPost) && (
      <nav class="post-nav post-nav--top">
        {prevPost ? (
          <a href={`/blog/${prevPost.id.replace(/\.mdx?$/, '')}`} class="post-nav-item prev">
            <div class="post-nav-label">← Previous Post</div>
            <div class="post-nav-title">{prevPost.data.title}</div>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/blog/${nextPost.id.replace(/\.mdx?$/, '')}`} class="post-nav-item next">
            <div class="post-nav-label">Next Post →</div>
            <div class="post-nav-title">{nextPost.data.title}</div>
          </a>
        ) : <div />}
      </nav>
    )}

    <!-- Table of Contents -->
    {tocItems.length > 0 && (
      <aside class="toc">
        <div class="toc-inner">
          <div class="toc-title">Table of Contents</div>
          <nav class="toc-nav">
            {tocItems.map((heading) => (
              <a
                href={`#${heading.slug}`}
                class:list={['toc-link', `toc-depth-${heading.depth}`]}
                data-slug={heading.slug}
              >
                {heading.text}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    )}

    <!-- Main Content -->
    <div class="post-content">
      {cover && (
        <Image src={cover} alt={title} width={800} height={450} class="post-cover" loading="lazy" />
      )}
      <div class="prose">
        <slot />
      </div>
    </div>

    <!-- Bottom Navigation -->
    {(prevPost || nextPost) && (
      <nav class="post-nav">
        {prevPost ? (
          <a href={`/blog/${prevPost.id.replace(/\.mdx?$/, '')}`} class="post-nav-item prev">
            <div class="post-nav-label">← Previous</div>
            <div class="post-nav-title">{prevPost.data.title}</div>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/blog/${nextPost.id.replace(/\.mdx?$/, '')}`} class="post-nav-item next">
            <div class="post-nav-label">Next →</div>
            <div class="post-nav-title">{nextPost.data.title}</div>
          </a>
        ) : <div />}
      </nav>
    )}
  </article>

  <!-- TOC scroll tracking -->
  <script is:inline>
    (function() {
      const tocLinks = document.querySelectorAll('.toc-link');
      if (!tocLinks.length) return;

      const headings = [];
      tocLinks.forEach(link => {
        const id = link.getAttribute('data-slug');
        const el = document.getElementById(id);
        if (el) headings.push({ id, el, link });
      });

      function updateActive() {
        let current = headings[0];
        for (const h of headings) {
          if (h.el.getBoundingClientRect().top <= 100) {
            current = h;
          }
        }
        tocLinks.forEach(l => l.classList.remove('active'));
        if (current) current.link.classList.add('active');
      }

      window.addEventListener('scroll', updateActive, { passive: true });
      updateActive();
    })();
  </script>
</BaseLayout>
